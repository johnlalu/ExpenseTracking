{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information",
      "Microsoft.Azure": "Information"
    }
  },
  "KeyVault": {
    "Enabled": true,
    "VaultUrl": "https://kv-expense-reimbursement.vault.azure.net/"
  },
  "Jwt": {
    "SecretKey": "dev-secret-key-this-is-not-secure-change-in-production-must-be-32-chars-long",
    "Issuer": "ExpenseReimbursementAPI",
    "Audience": "ExpenseReimbursementApp",
    "ExpirationMinutes": 15,
    "RefreshTokenExpirationDays": 7
  },
  "CosmosDb": {
    "EndpointUri": "https://id-east-us.documents.azure.com:443/",
    "PrimaryKey": "REDACTED_COSMOS_KEY=",
    "DatabaseName": "db-expense-managemr-cosmos",
    "ContainerName": "ci-expense-manager"
  },
  "ApplicationInsights": {
    "InstrumentationKey": "dev-instrumentation-key"
  }
}
